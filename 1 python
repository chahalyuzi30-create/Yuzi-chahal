# Tic Tac Toe Game: Player = X, AI = O
board = [" "] * 9
wins = [
    (0,1,2), (3,4,5), (6,7,8),
    (0,3,6), (1,4,7), (2,5,8),
    (0,4,8), (2,4,6)
]
def show():
    for i in range(0, 9, 3):
        print(board[i], "|", board[i+1], "|", board[i+2])
    print()
def check(player):
    for a, b, c in wins:
        if board[a] == board[b] == board[c] == player:
            return True
    return False
while " " in board:
    show()
    pos = int(input("Enter position (1-9): ")) - 1
    if board[pos] != " ":
        print("Position already occupied!")
        continue
    board[pos] = "X"
    if check("X"):
        show()
        print("Player X Wins")
        break
    if " " not in board:
        show()
        print("Match Draw")

        break
    for i in range(9):
        if board[i] == " ":
            board[i] = "O"
            print("AI played at", i + 1)
            break
    if check("O"):
        show()
        print("AI Wins")
        break
else:
    show()
    print("Match Draw")

import numpy as np
from sklearn.tree import DecisionTreeClassifier
def count_inversions(state):
    arr = [x for x in state if x != 0] 
    inv = 0
    for i in range(len(arr)):
        for j in range(i + 1, len(arr)):
            if arr[i] > arr[j]:
                inv += 1
    return inv
def get_label(state):
    return count_inversions(state) % 2
states = [
    [1,2,3,4,5,6,7,8,0],
    [1,2,3,4,5,6,8,7,0],
    [1,2,3,4,5,6,7,0,8],
    [1,2,3,5,4,6,7,8,0],
    [1,3,2,4,5,6,7,8,0],
    [1,2,3,4,6,5,7,8,0]
]
labels = [get_label(s) for s in states]
model = DecisionTreeClassifier()
model.fit(states, labels)
print("Enter 8 numbers for the 8-puzzle (1-8). Blank will be added automatically as 0.")
try:
    user_input = list(map(int, input("Enter 8 numbers separated by space: ").split()))    
    if len(user_input) != 8:
        print("Error: Enter exactly 8 numbers.")
    else:
        user_input.append(0)  
        total_inv = count_inversions(user_input)
        parity = "Even" if total_inv % 2 == 0 else "Odd"
        test_state = np.array(user_input).reshape(1, -1)
        prediction = model.predict(test_state)[0]

        print("\nPuzzle State:", user_input)
        print("Total Inversions:", total_inv)
        print("Inversion Parity:", parity) 
        if prediction == 0:
            print("This state belongs to EVEN set → Reachable from goal state")
        else:
            print("This state belongs to ODD set → Not reachable from goal state")
except ValueError:
    print("Error: Please enter only integers.")

