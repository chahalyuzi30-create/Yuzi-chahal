import pandas as pd
data = [
 ['Sunny','Warm','Normal','Strong','Warm','Same','Yes'],
 ['Sunny','Warm','High','Strong','Warm','Same','Yes'],
 ['Rainy','Cold','High','Strong','Warm','Change','No'],
 ['Sunny','Warm','High','Strong','Cool','Change','Yes']
]
df = pd.DataFrame(data)
print("Dataset:\n", df)
# ---------------- FIND-S ----------------
S = ['0'] * (len(df.columns)-1)
for row in df.values:
    if row[-1] == 'Yes':
        for i in range(len(S)):
            if S[i] == '0':
                S[i] = row[i]
            elif S[i] != row[i]:
                S[i] = '?'
print("\nFind-S Hypothesis :", S)
# -------- CANDIDATE ELIMINATION --------
G = [['?'] * len(S)]
for row in df.values:
    x, label = row[:-1], row[-1]
    if label == 'No':
        new_G = []
        for g in G:
            for i in range(len(S)):
                if g[i] == '?' and S[i] != x[i]:
                    h = g.copy()
                    h[i] = S[i]
                    new_G.append(h)
        G = new_G
print("\nFinal S :", S)
print("\nFinal G :")
for g in G:
    print(g)

